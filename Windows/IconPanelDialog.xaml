<Window x:Class="Jade.Windows.IconPanelDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Panel" Height="450" Width="400"
        Background="#1E1E1E"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    
    <Border BorderThickness="1" BorderBrush="#3E3E42">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Custom Title Bar -->
            <Border x:Name="TitleBar" Grid.Row="0" Background="#252526" Height="30" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock Text="Panel" Foreground="#CCCCCC" FontSize="12" VerticalAlignment="Center" Margin="10,0"/>
            </Border>
            
            <!-- Content -->
            <Grid Grid.Row="1" Margin="15">
                <StackPanel>
                    <!-- Skinscale Control -->
                    <TextBlock Text="Skinscale Control" 
                               FontSize="14" 
                               FontWeight="SemiBold"
                               Foreground="#CCCCCC" 
                               Margin="0,0,0,10"/>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBox x:Name="SkinscaleTextBox"
                                 Width="80"
                                 Height="30"
                                 Background="#2D2D30"
                                 Foreground="#CCCCCC"
                                 BorderBrush="#3E3E42"
                                 BorderThickness="1"
                                 Padding="8,6"
                                 FontSize="13"
                                 VerticalContentAlignment="Center"
                                 Text="1.0"/>
                        
                        <TextBox x:Name="PercentageTextBox"
                                 Width="60"
                                 Height="30"
                                 Background="#2D2D30"
                                 Foreground="#CCCCCC"
                                 BorderBrush="#3E3E42"
                                 BorderThickness="1"
                                 Padding="8,6"
                                 FontSize="13"
                                 VerticalContentAlignment="Center"
                                 Text="100"
                                 Margin="10,0,0,0"
                                 TextChanged="OnPercentageChanged"/>
                        
                        <TextBlock Text="%"
                                   FontSize="13"
                                   Foreground="#CCCCCC"
                                   VerticalAlignment="Center"
                                   Margin="5,0,10,0"/>
                        
                        <Button x:Name="ApplySkinscaleButton"
                                Content="✓"
                                Width="30"
                                Height="30"
                                Background="#2D7A2D"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="16"
                                FontWeight="Bold"
                                Cursor="Hand"
                                Click="OnApplySkinscale"
                                ToolTip="Apply skinscale value"/>
                        
                        <Button x:Name="AddSkinscaleButton"
                                Content="+"
                                Width="30"
                                Height="30"
                                Margin="5,0,0,0"
                                Background="#DAA520"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="18"
                                FontWeight="Bold"
                                Cursor="Hand"
                                Click="OnAddSkinscale"
                                ToolTip="Add skinScale to file"/>
                    </StackPanel>
                    
                    <TextBlock x:Name="StatusTextBlock"
                               Text=""
                               FontSize="11"
                               Foreground="#808080"
                               Margin="0,5,0,0"/>
                    
                    <!-- Material Override Control -->
                    <TextBlock Text="Material Override Control" 
                               FontSize="14" 
                               FontWeight="SemiBold"
                               Foreground="#CCCCCC" 
                               Margin="0,20,0,10"/>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button x:Name="AddMaterialOverrideButton"
                                Content="+ Add materialOverride"
                                Width="180"
                                Height="30"
                                Background="#DAA520"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="12"
                                FontWeight="Bold"
                                Cursor="Hand"
                                Click="OnAddMaterialOverride"
                                ToolTip="Add materialOverride structure"/>
                    </StackPanel>
                    
                    <StackPanel x:Name="MaterialOverrideOptionsPanel" Visibility="Collapsed" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <Button x:Name="AddTextureButton"
                                    Content="+ Add Texture"
                                    Width="120"
                                    Height="30"
                                    Background="#2D7A2D"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontSize="12"
                                    FontWeight="Bold"
                                    Cursor="Hand"
                                    Click="OnAddTexture"
                                    ToolTip="Add texture override entry"/>
                            
                            <Button x:Name="AddMaterialButton"
                                    Content="+ Add Material"
                                    Width="120"
                                    Height="30"
                                    Margin="10,0,0,0"
                                    Background="#2D7A2D"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontSize="12"
                                    FontWeight="Bold"
                                    Cursor="Hand"
                                    Click="OnAddMaterial"
                                    ToolTip="Add material override entry"/>
                        </StackPanel>
                    </StackPanel>
                    
                    <TextBlock x:Name="MaterialStatusTextBlock"
                               Text=""
                               FontSize="11"
                               Foreground="#808080"
                               Margin="0,5,0,0"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
