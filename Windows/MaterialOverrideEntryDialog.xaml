<Window x:Class="Jade.Windows.MaterialOverrideEntryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Entry" Height="210" Width="350"
        Background="#1E1E1E"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    
    <Border BorderThickness="1" BorderBrush="#3E3E42">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Custom Title Bar -->
            <Border x:Name="TitleBar" Grid.Row="0" Background="#252526" Height="30" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock x:Name="TitleTextBlock" Text="Add Entry" Foreground="#CCCCCC" FontSize="12" VerticalAlignment="Center" Margin="10,0"/>
            </Border>
            
            <!-- Content -->
            <Grid Grid.Row="1" Margin="12">
                <StackPanel>
                    <TextBlock x:Name="PathLabelTextBlock" Text="Path:" 
                               FontSize="12" 
                               Foreground="#CCCCCC" 
                               Margin="0,0,0,4"/>
                    
                    <TextBox x:Name="PathTextBox"
                             Height="28"
                             Background="#2D2D30"
                             Foreground="#CCCCCC"
                             BorderBrush="#3E3E42"
                             BorderThickness="1"
                             Padding="6,4"
                             FontSize="11"
                             VerticalContentAlignment="Center"
                             Margin="0,0,0,10"/>
                    
                    <TextBlock Text="Submesh:" 
                               FontSize="12" 
                               Foreground="#CCCCCC" 
                               Margin="0,0,0,4"/>
                    
                    <TextBox x:Name="SubmeshTextBox"
                             Height="28"
                             Background="#2D2D30"
                             Foreground="#CCCCCC"
                             BorderBrush="#3E3E42"
                             BorderThickness="1"
                             Padding="6,4"
                             FontSize="11"
                             VerticalContentAlignment="Center"
                             Text="submesh"
                             Margin="0,0,0,10"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Button x:Name="AcceptButton"
                                Grid.Column="0"
                                Content="✓ Accept"
                                Height="30"
                                Background="#2D7A2D"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="12"
                                FontWeight="Bold"
                                Cursor="Hand"
                                Click="OnAccept"/>
                        
                        <Button x:Name="CancelButton"
                                Grid.Column="2"
                                Content="✕ Cancel"
                                Height="30"
                                Background="#8B0000"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="12"
                                FontWeight="Bold"
                                Cursor="Hand"
                                Click="OnCancel"/>
                    </Grid>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
