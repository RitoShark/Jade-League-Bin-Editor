<Window x:Class="Jade.Windows.ParticlePanelDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Particle Panel" Height="450" Width="400"
        Background="#1E1E1E"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    
    <Border BorderThickness="1" BorderBrush="#3E3E42">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Custom Title Bar -->
            <Border x:Name="TitleBar" Grid.Row="0" Background="#252526" Height="30" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock Text="Particle Editing" Foreground="#CCCCCC" FontSize="12" VerticalAlignment="Center" Margin="10,0"/>
            </Border>
            
            <!-- Content -->
            <Grid Grid.Row="1" Margin="15">
                <TextBlock Text="Particle Editing Placeholder" 
                           FontSize="14" 
                           Foreground="#808080" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"/>
            </Grid>
        </Grid>
    </Border>
</Window>
