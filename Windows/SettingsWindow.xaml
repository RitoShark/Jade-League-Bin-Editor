<Window x:Class="Jade.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Jade Settings" Height="700" Width="1000"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize">
    
    <Window.Resources>
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1C97EA"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </Window.Resources>
    
    <Border BorderThickness="1" BorderBrush="#3E3E42">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Custom Title Bar -->
            <Border x:Name="TitleBar" Grid.Row="0" Background="#252526" Height="30" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                    <Image Source="/jade.ico" Width="16" Height="16" Margin="0,0,8,0"/>
                    <TextBlock Text="Jade Settings" Foreground="#CCCCCC" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
            
            <!-- Content -->
            <Grid Grid.Row="1" Margin="25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Title -->
                <StackPanel Grid.Row="0">
                    <TextBlock Text="Settings" FontSize="32" FontWeight="Bold" Foreground="White" Margin="0,0,0,5"/>
                    <TextBlock Text="Configure application behavior and preferences" FontSize="16" Foreground="#888888"/>
                </StackPanel>

                <!-- 3-Column Settings Layout -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Column 1: Hashes -->
                    <Border x:Name="HashFilesBox" Grid.Column="0" Background="#252526" BorderBrush="#3E3E42" BorderThickness="1" CornerRadius="4" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Hash Files" FontSize="18" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,15"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,15" FontSize="13">
                                Hash files are used to convert hex values into readable names.
                            </TextBlock>
                            
                            <Button Content="Download Hashes" Click="OnDownloadHashes" Style="{StaticResource ModernButtonStyle}" HorizontalAlignment="Stretch" Margin="0,0,0,8"/>
                            <Button Content="Open Hashes Folder" Click="OnOpenHashesFolder" Style="{StaticResource ModernButtonStyle}" HorizontalAlignment="Stretch" Margin="0,0,0,8" Background="#3E3E42"/>
                            
                            <Separator Background="#3E3E42" Margin="0,10"/>
                            
                            <Button x:Name="AutoDownloadToggleButton" 
                                    Content="Auto-download: Disabled" 
                                    Click="OnToggleAutoDownload" 
                                    HorizontalAlignment="Stretch"
                                    Margin="0,0,0,8"
                                    Style="{StaticResource ModernButtonStyle}"
                                    Background="#7A2D2D"/>
                                    
                            <Button x:Name="PreloadHashToggleButton" 
                                    Content="Preload hashes: Disabled" 
                                    Click="OnTogglePreloadHash" 
                                    HorizontalAlignment="Stretch"
                                    Margin="0,0,0,8"
                                    Style="{StaticResource ModernButtonStyle}"
                                    Background="#7A2D2D"
                                    ToolTip="When enabled: Fast conversion but uses ~500MB of RAM."/>
                                    
                            <Button x:Name="BinaryFormatToggleButton" 
                                    Content="Binary format: Disabled" 
                                    Click="OnToggleBinaryFormat" 
                                    HorizontalAlignment="Stretch"
                                    Style="{StaticResource ModernButtonStyle}"
                                    Background="#7A2D2D"
                                    ToolTip="When enabled: Converts hashes to binary for faster loading."/>

                            <TextBlock x:Name="HashStatusText" Margin="0,15,0,5" FontSize="11" Foreground="#858585" TextWrapping="Wrap"/>
                            <TextBlock x:Name="HashFolderPath" FontSize="11" Foreground="#858585" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Column 2: Temporary Files -->
                    <Border x:Name="TempFilesBox" Grid.Column="2" Background="#252526" BorderBrush="#3E3E42" BorderThickness="1" CornerRadius="4" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Temporary Files" FontSize="18" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,15"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,15" FontSize="13">
                                Temporary files are created when converting BIN files for editing.
                            </TextBlock>
                            
                            <Button Content="Clear Temp Folder" Click="OnClearTempFolder" Style="{StaticResource ModernButtonStyle}" HorizontalAlignment="Stretch" Margin="0,0,0,8" Background="#7A2D2D"/>
                            <Button Content="Open Temp Folder" Click="OnOpenTempFolder" Style="{StaticResource ModernButtonStyle}" HorizontalAlignment="Stretch" Margin="0,0,0,8" Background="#3E3E42"/>
                            
                            <Separator Background="#3E3E42" Margin="0,10"/>

                            <Button x:Name="AutoClearToggleButton" 
                                    Content="Auto-clear: Enabled" 
                                    Click="OnToggleAutoClear" 
                                    HorizontalAlignment="Stretch"
                                    Style="{StaticResource ModernButtonStyle}"
                                    Background="#2D7A2D"/>

                            <TextBlock x:Name="TempFolderPath" Margin="0,15,0,0" FontSize="11" Foreground="#858585" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Column 3: App Behavior & Associations -->
                    <Border x:Name="AppBehaviorBox" Grid.Column="4" Background="#252526" BorderBrush="#3E3E42" BorderThickness="1" CornerRadius="4" Padding="20">
                        <StackPanel>
                            <TextBlock Text="App Behavior" FontSize="18" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,15"/>
                            
                            <Button x:Name="MinimizeToTrayToggleButton" 
                                    Content="Minimize to Tray: Disabled" 
                                    Click="OnToggleMinimizeToTray" 
                                    HorizontalAlignment="Stretch"
                                    Margin="0,0,0,8"
                                    Style="{StaticResource ModernButtonStyle}"
                                    Background="#7A2D2D"/>

                            <Button x:Name="RunAtStartupToggleButton" 
                                    Content="Run at Startup: Disabled" 
                                    Click="OnToggleRunAtStartup" 
                                    HorizontalAlignment="Stretch"
                                    Style="{StaticResource ModernButtonStyle}"
                                    Background="#7A2D2D"/>

                            <Separator Background="#3E3E42" Margin="0,15"/>

                            <TextBlock Text="File Association" FontSize="16" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,15"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,15" FontSize="13">
                                Register Jade as a handler for .bin files.
                            </TextBlock>

                            <Button x:Name="RegisterBinButton" 
                                    Content="Register .bin" 
                                    Click="OnRegisterBinAssociation" 
                                    HorizontalAlignment="Stretch"
                                    Margin="0,0,0,8"
                                    Style="{StaticResource ModernButtonStyle}"/>
                            <Button x:Name="UnregisterBinButton" 
                                    Content="Unregister" 
                                    Click="OnUnregisterBinAssociation" 
                                    HorizontalAlignment="Stretch"
                                    Style="{StaticResource ModernButtonStyle}"
                                    Background="#7A2D2D"/>

                            <TextBlock x:Name="FileAssociationStatus" Margin="0,15,0,0" FontSize="11" Foreground="#858585" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>
        
                <!-- Action Buttons -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                    <Button Content="Restart App" Click="OnRestart" Margin="0,0,15,0" Style="{StaticResource ModernButtonStyle}" Background="#2D7A2D"/>
                    <Button Content="Close" Click="OnClose" Style="{StaticResource ModernButtonStyle}" Background="#3E3E42"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
