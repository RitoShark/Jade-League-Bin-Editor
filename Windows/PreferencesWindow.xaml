<Window x:Class="Jade.Windows.PreferencesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Jade Preferences" Height="500" Width="800"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize">
    
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </Window.Resources>
    
    <Border BorderThickness="1" BorderBrush="{DynamicResource SubtleBorderBrush}" Background="{DynamicResource WindowBackgroundBrush}" CornerRadius="{DynamicResource GlobalCornerRadius}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Custom Title Bar -->
            <Border x:Name="TitleBar" Grid.Row="0" Background="{DynamicResource TitleBarBackgroundBrush}" Height="30" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" CornerRadius="{DynamicResource GlobalCornerRadius}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                    <Image Source="/jade.ico" Width="16" Height="16" Margin="0,0,8,0"/>
                    <TextBlock Text="Jade Preferences" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
            
            <!-- Content -->
            <Grid Grid.Row="1" Margin="25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Title -->
                <StackPanel Grid.Row="0">
                    <TextBlock Text="Preferences" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,5"/>
                    <TextBlock Text="Configure your experience" FontSize="16" Foreground="{DynamicResource MutedTextBrush}"/>
                </StackPanel>

                <!-- Preference Options -->
                <Border x:Name="ContentBorder" Grid.Row="2" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource SubtleBorderBrush}" BorderThickness="1" CornerRadius="{DynamicResource GlobalCornerRadius}" Padding="20">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Import Linked Bin Files Option -->
                            <StackPanel Margin="0,0,0,20">
                                <CheckBox x:Name="ImportLinkedBinsCheckBox" 
                                          Content="Import Linked Bin Files" 
                                          FontSize="16" 
                                          Foreground="{DynamicResource PrimaryTextBrush}"
                                          Checked="OnImportLinkedBinsChanged"
                                          Unchecked="OnImportLinkedBinsChanged"/>
                                <TextBlock Text="When enabled, opening a bin file will automatically open all linked bin files found in the DATA folder." 
                                           TextWrapping="Wrap" 
                                           Foreground="{DynamicResource MutedTextBrush}" 
                                           FontSize="12" 
                                           Margin="20,5,0,0"/>
                                
                                <!-- Sub-option: Recursive loading -->
                                <CheckBox x:Name="RecursiveLinkedBinsCheckBox" 
                                          Content="Also load files linked inside imported files" 
                                          FontSize="14" 
                                          Foreground="{DynamicResource MutedTextBrush}"
                                          Margin="30,10,0,0"
                                          IsEnabled="{Binding IsChecked, ElementName=ImportLinkedBinsCheckBox}"
                                          Checked="OnRecursiveLinkedBinsChanged"
                                          Unchecked="OnRecursiveLinkedBinsChanged"/>
                                <TextBlock Text="Recursively opens linked files from within the imported linked files (may open many tabs)." 
                                           TextWrapping="Wrap" 
                                           Foreground="{DynamicResource MutedTextBrush}" 
                                           FontSize="11" 
                                           Margin="50,3,0,0"/>
                            </StackPanel>

                            <!-- Sticky Scroll Option -->
                            <StackPanel Margin="0,0,0,20">
                                <CheckBox x:Name="StickyScrollCheckBox" 
                                          Content="Enable Sticky Scroll" 
                                          FontSize="16" 
                                          Foreground="{DynamicResource PrimaryTextBrush}"
                                          Checked="OnStickyScrollChanged"
                                          Unchecked="OnStickyScrollChanged"/>
                                <TextBlock Text="Sticks the current parent context (braces) to the top of the editor while scrolling, similar to VS Code." 
                                           TextWrapping="Wrap" 
                                           Foreground="{DynamicResource MutedTextBrush}" 
                                           FontSize="12" 
                                           Margin="20,5,0,0"/>
                            </StackPanel>
                            

                        </StackPanel>
                    </ScrollViewer>
                </Border>
        
                <!-- Action Buttons -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                    <Button Content="Close" Click="OnClose" Background="{DynamicResource SubtleBorderBrush}"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
